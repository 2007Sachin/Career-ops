# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key — safe to expose to browser (RLS enforces access)
SUPABASE_KEY=your-supabase-anon-key

# Service role key — NEVER expose to browser; backend only
# From: Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Frontend (NEXT_PUBLIC_ prefix = safe to expose to browser) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API base URL (used by SocialProofStep and any client → backend calls)
# Local dev: http://localhost:8000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: embed a Loom/YouTube URL for the onboarding video step
NEXT_PUBLIC_INTRO_VIDEO_URL=

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── GitHub ingestion ──────────────────────────────────────────────────────────
# Personal access token for the GitHub API (read:user, read:org scopes)
GITHUB_TOKEN=your-github-personal-access-token

# ── Outreach agent dependencies ───────────────────────────────────────────────
FIRECRAWL_API_KEY=your-firecrawl-api-key
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# ── App ───────────────────────────────────────────────────────────────────────
# Secret used to sign custom JWT claims for recruiter accounts
# Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-chars

# Admin key for /api/admin/* endpoints — generate: openssl rand -hex 32
ADMIN_API_KEY=your-admin-api-key

# Comma-separated list of allowed CORS origins
# Local dev: http://localhost:3000
# Production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000
